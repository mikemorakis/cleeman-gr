{
  "name": "cleeman.gr",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i src/css/input.css -o src/css/output.css --minify",
    "build:11ty": "npx @11ty/eleventy",
    "build": "npm run build:css && npm run build:11ty",
    "dev:css": "npx @tailwindcss/cli -i src/css/input.css -o src/css/output.css --watch",
    "dev:11ty": "npx @11ty/eleventy --serve",
    "dev": "npm run build:css && concurrently \"npm run dev:css\" \"npm run dev:11ty\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1"
  }
}
